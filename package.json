{
    "name": "ganita-kit",
    "version": "1.0.0",
    "description": "Unified AI agent toolkit for Pi -- webclaw, bloks, tldr, fastedit, web search, code search, Google Surf",
    "main": "./index.ts",
    "scripts": {
        "check": "biome check ./",
        "check:fix": "biome check --fix ./",
        "typecheck": "tsc --noEmit"
    },
    "author": "pwnholic",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pwnholic/ganita-kit.git"
    },
    "type": "module",
    "keywords": [
        "pi-package"
    ],
    "pi": {
        "extensions": [
            "./index.ts"
        ],
        "skills": [
            "./skills"
        ]
    },
    "dependencies": {
        "google-surf-mcp": "^0.4.0"
    },
    "peerDependencies": {
        "@mariozechner/pi-ai": "*",
        "@mariozechner/pi-coding-agent": "*",
        "typebox": "*"
    },
    "peerDependenciesMeta": {
        "@mariozechner/pi-ai": {
            "optional": true
        },
        "@mariozechner/pi-coding-agent": {
            "optional": true
        },
        "typebox": {
            "optional": true
        }
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@mariozechner/pi-coding-agent": "^0.70.6",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    }
}
